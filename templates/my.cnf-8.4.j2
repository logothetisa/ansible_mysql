#======================================================================
#  MANAGED BY ANSIBLE — DO NOT EDIT THIS FILE BY HAND
#  Project : mysql_mycnf
#  Rendered: {{ ansible_managed }}
#  Host    : {{ inventory_hostname }}
#  Source  : templates/my.cnf.j2
#======================================================================

[mysql]
default_character_set = utf8mb4
socket = /opt/mysql/data/db/mysql.sock
prompt='\u@\h:\d> '


[mysqld]
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

#-----------------------------------------------------------
#
# Variables that need values   (templated per-host by Ansible)
#
#------------------------------------------------------------
server_id={{ ans_server_id | mandatory }}
report_host={{ ans_report_host | mandatory }}
innodb_buffer_pool_size={{ ans_innodb_buffer_pool_size | mandatory }}
default_time_zone = {{ ans_default_time_zone | mandatory }}
sql_generate_invisible_primary_key = {{ ans_sql_generate_invisible_primary_key | mandatory }}
#mysql_native_password=ON


#--------------------------------------------------------------------
#
# Percona PMM2 required
#
#--------------------------------------------------------------------
#performance_schema=ON
#performance-schema-instrument='statement/%=ON'
#performance-schema-consumer-statements-digest=ON
#innodb_monitor_enable=all
#--------------------------------------------------------------------



#-------------------------------------------------------------------
#
#  Innodb cluster/group replication
#
# The use of other storage engines, including the temporary MEMORY storage engine,
# might cause errors in Group Replication.
#
# Set the disabled_storage_engines system variable as follows to prevent their use:
#-------------------------------------------------------------------

#disabled_storage_engines="MyISAM,BLACKHOLE,FEDERATED,ARCHIVE,MEMORY"




#--------------------------------------------------------------------
#
# Paths
#
#----------------------------------------------------------------------

datadir                         = {{ ans_mysql_data_dir       | mandatory }}/data/db
socket                          = {{ ans_mysql_data_dir       | mandatory }}/data/db/mysql.sock
log_error                       = {{ ans_mysql_data_dir       | mandatory }}/log/error_log/mysql_error.log
pid_file                        = {{ ans_mysql_data_dir       | mandatory }}/log/mysql.pid
general_log_file                = {{ ans_mysql_data_dir       | mandatory }}/log/general_log/general.log
slow_query_log_file             = {{ ans_mysql_data_dir       | mandatory }}/log/slow_log/slow_query.log
tmpdir                          = {{ ans_mysql_data_dir       | mandatory }}/log/tmp

log_bin                         = {{ ans_mysql_log_bin_dir    | mandatory }}/binlog.log
log_bin_index                   = {{ ans_mysql_log_bin_dir    | mandatory }}/binlog.index

relay_log                       = {{ ans_mysql_relay_log_dir  | mandatory }}/relaylog.log
relay_log_index                 = {{ ans_mysql_relay_log_dir  | mandatory }}/relaylog.index

innodb_log_group_home_dir       = {{ ans_innodb_log_group_home_dir | mandatory }}

#----------------------------------------------------------------------


#--------------------------------------------------------------------
#
# General Configuration
#
#----------------------------------------------------------------------
user = mysql
port = 3306
gtid_mode = ON
enforce_gtid_consistency = ON

binlog_expire_logs_seconds=172800
log_bin_trust_function_creators = ON

event_scheduler = OFF

slow_query_log = 0
long_query_time = 15

lower_case_table_names = 1
transaction_isolation = READ-COMMITTED
performance_schema_show_processlist=on

innodb_flush_log_at_trx_commit=1
sync_binlog=1
#----------------------------------------------------------------------


#--------------------------------------------------------------------
#
# Audit
#
#----------------------------------------------------------------------
#audit_log=FORCE_PLUS_PERMANENT
#audit_log_file=/opt/mysql/audit/audit.log
#audit_log_format=JSON
#audit_log_compression=GZIP
#audit_log_rotate_on_size=128K
#audit_log_flush=off
#audit_log_buffer_size=16K
#----------------------------------------------------------------------


#--------------------------------------------------------------------
#
# InnoDB Encryption
#
#----------------------------------------------------------------------
# NOTE:
#  Use the keyring component manifest and configuration files
#  Old keyring plugin is not supported
#----------------------------------------------------------------------

#--------------------------------------------------------------------
#
# MySQL Thread Pool
#
#--------------------------------------------------------------------
#plugin_load-add=thread_pool.so
#plugin_dir=/usr/lib64/mysql/plugin/
#plugin_load=thread_pool.so
#thread_pool_size=36
#thread_pool_high_priority_connection=1
#thread_pool_stall_limit=10
#--------------------------------------------------------------------


#--------------------------------------------------------------------
#
# Other Plugins
#
#---------------------------------------------------------------------
#plugin_load=libscramble_serial=libscramble_serial.so  # Optional - after request
#--------------------------------------------------------------------


#--------------------------------------------------------------------
#
# Replication related Configuration
#
#--------------------------------------------------------------------
relay_log_recovery = ON
sync_source_info = 10000

skip_replica_start=OFF
log_replica_updates = ON

report_port=3306
replica_parallel_workers=8
replica_preserve_commit_order=ON

# IMPORTANT: read_only=1 must be set on all master and replicas, set read_only=0
#            only via MySQL CLI i.e. 'set global read_only=0' on the master
#            after carefully verifying which server is master since Orchestrator
#            is deployed for automatic failover and the replication topology is
#            dynamic!!! ProxySQL forwards WRITE traffic to ANY nodes which are RW
#            so you must ensure only ONE MySQL instance (the master) is RW at any time
read_only=1
super_read_only=1
#----------------------------------------------------------------------

#----------------------------------------------------------------------
#
# InnoDB Configuration
#
#----------------------------------------------------------------------
large_pages={{ ans_large_pages | mandatory }} 
innodb_numa_interleave=ON   ## ON -> default 8.4 LTS

# The maximum depth of search performed by the query optimizer.
# If set to 0, the system automatically picks a reasonable value
optimizer_search_depth = 0

innodb_file_per_table = ON
innodb_flush_method=O_DIRECT  ## O_DIRECT -> default 8.4 LTS

innodb_log_buffer_size={{ ans_innodb_log_buffer_size | mandatory }}   ## 64M -> default 8.4 LTS
innodb_redo_log_capacity={{ ans_innodb_redo_log_capacity | mandatory }}

innodb_buffer_pool_instances={{ ans_innodb_buffer_pool_instances | mandatory }}
innodb_io_capacity={{ ans_innodb_io_capacity | mandatory }}     ## 10000 -> default 8.4. LTS
innodb_io_capacity_max={{ ans_innodb_io_capacity_max | mandatory }} ## 2 * innodb_io_capacity  -> default 8.4. LTS

#innodb_buffer_pool_chunk_size=256M
#innodb_write_io_threads=8
#innodb_read_io_threads=8
#innodb_purge_threads=8
#innodb_page_cleaners=8
#innodb_ddl_threads
#innodb_ddl_buffer_size


#----------------------------------------------------------------------


#--------------------------------------------------------------------
#
# Other Configuration
#
#--------------------------------------------------------------------
max_connections=2000
skip_name_resolve=on
open_files_limit=65535
table_open_cache=4000
#thread_cache_size=128
#tmp_table_size = 32M
#max_heap_table_size = 32M
#--------------------------------------------------------------------


[mysqld_safe]
log_error = {{ ans_mysql_data_dir | mandatory }}/log/error_log/mysql_error.log
pid_file  = {{ ans_mysql_data_dir | mandatory }}/log/mysql.pid

#
# include all files from the config directory
#
# !includedir /etc/my.cnf.d

[client]
socket = {{ ans_mysql_data_dir | mandatory }}/data/db/mysql.sock
